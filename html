                <h2 class="font-serif text-4xl md:text-6xl font-semibold tracking-tight text-stone-900">Заказ букета</h2>
            </div>
        </div>
        <!-- Интерьер -->
        <div onclick="selectService('interior')" class="split-half flex-1 bg-gradient-to-bl from-emerald-200 via-emerald-100 to-emerald-50 cursor-pointer flex items-center justify-center group relative">
            <div class="absolute inset-0 bg-gradient-to-bl from-emerald-400/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="text-center z-10 p-8 transform transition-transform duration-500">
