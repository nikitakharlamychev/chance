                                    </div>
                                    <div class="flex items-center gap-2 bg-stone-50 p-1 rounded-lg border border-stone-100" onclick="event.stopPropagation()">
                                        <button class="w-6 h-6 flex items-center justify-center rounded-md text-stone-500 hover:bg-white hover:shadow-sm hover:text-stone-900 transition-all text-sm" onclick="changeQuantity('peonies', -1)">−</button>
