                            </div>

                            <div class="flower-card border border-stone-200/70 rounded-2xl p-4 bg-white cursor-pointer hover:shadow-sm hover:border-stone-300" id="flower-tulips" onclick="toggleFlower('tulips')">
                                <div class="flex items-start justify-between mb-4">
                                    <div>
                                        <div class="font-medium text-stone-800 text-sm mb-0.5">Тюльпаны</div>
                                        <div class="text-xs text-stone-400">от 90 ₽/шт</div>
                                    </div>
                                    <div class="flex items-center gap-2 bg-stone-50 p-1 rounded-lg border border-stone-100" onclick="event.stopPropagation()">
                                        <button class="w-6 h-6 flex items-center justify-center rounded-md text-stone-500 hover:bg-white hover:shadow-sm hover:text-stone-900 transition-all text-sm" onclick="changeQuantity('tulips', -1)">−</button>
                                        <span class="text-xs font-medium text-stone-700 min-w-[1rem] text-center" id="qty-tulips">0</span>
                                        <button class="w-6 h-6 flex items-center justify-center rounded-md text-stone-500 hover:bg-white hover:shadow-sm hover:text-stone-900 transition-all text-sm" onclick="changeQuantity('tulips', 1)">+</button>
